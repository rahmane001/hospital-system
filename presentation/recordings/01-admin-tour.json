{
  "title": "HMS DApp — Admin Tour (Demo Part 1A)",
  "steps": [
    {
      "type": "setViewport",
      "width": 1920,
      "height": 1080,
      "deviceScaleFactor": 1,
      "isMobile": false,
      "hasTouch": false,
      "isLandscape": true
    },
    {
      "type": "navigate",
      "url": "http://localhost:3000/login",
      "assertedEvents": [{ "type": "navigation", "url": "http://localhost:3000/login" }]
    },
    {
      "type": "waitForElement",
      "selectors": [["input[type=\"email\"]"]],
      "timeout": 5000
    },
    {
      "type": "click",
      "target": "main",
      "selectors": [["input[type=\"email\"]"]],
      "offsetX": 10,
      "offsetY": 10
    },
    {
      "type": "change",
      "value": "admin@hms.com",
      "selectors": [["input[type=\"email\"]"]]
    },
    {
      "type": "click",
      "target": "main",
      "selectors": [["input[type=\"password\"]"]],
      "offsetX": 10,
      "offsetY": 10
    },
    {
      "type": "change",
      "value": "Password123!",
      "selectors": [["input[type=\"password\"]"]]
    },
    {
      "type": "click",
      "target": "main",
      "selectors": [["button[type=\"submit\"]"]]
    },
    {
      "type": "waitForElement",
      "selectors": [["aria/Dashboard"], ["text/Dashboard"]],
      "timeout": 8000
    },
    {
      "type": "waitForElement",
      "selectors": [["text/Total Patients"], [".stat-card"]],
      "timeout": 8000
    },
    {
      "type": "customStep",
      "name": "pause-on-dashboard",
      "parameters": { "ms": 4000 }
    },
    {
      "type": "click",
      "target": "main",
      "selectors": [["aria/Analytics"], ["text/Analytics"]]
    },
    {
      "type": "customStep",
      "name": "pause-on-analytics",
      "parameters": { "ms": 5000 }
    },
    {
      "type": "click",
      "target": "main",
      "selectors": [["aria/Blockchain Logs"], ["text/Blockchain Logs"]]
    },
    {
      "type": "waitForElement",
      "selectors": [["text/On-Chain Record Counts"]],
      "timeout": 6000
    },
    {
      "type": "customStep",
      "name": "pause-on-blockchain",
      "parameters": { "ms": 5000 }
    },
    {
      "type": "click",
      "target": "main",
      "selectors": [["aria/Audit Log"], ["text/Audit Log"]]
    },
    {
      "type": "customStep",
      "name": "pause-on-audit",
      "parameters": { "ms": 5000 }
    }
  ]
}
