{
  "title": "HMS DApp \u2014 Admin Verifies the New Tx (Demo Part 1C)",
  "steps": [
    {
      "type": "setViewport",
      "width": 1920,
      "height": 1080,
      "deviceScaleFactor": 1,
      "isMobile": false,
      "hasTouch": false,
      "isLandscape": true
    },
    {
      "type": "navigate",
      "url": "http://localhost:3000/login"
    },
    {
      "type": "waitForElement",
      "selectors": [
        [
          "input[type=\"email\"]"
        ]
      ],
      "timeout": 5000
    },
    {
      "type": "click",
      "selectors": [
        [
          "input[type=\"email\"]"
        ]
      ],
      "target": "main",
      "offsetX": 5,
      "offsetY": 5
    },
    {
      "type": "change",
      "value": "admin@hms.com",
      "selectors": [
        [
          "input[type=\"email\"]"
        ]
      ]
    },
    {
      "type": "click",
      "selectors": [
        [
          "input[type=\"password\"]"
        ]
      ],
      "target": "main",
      "offsetX": 5,
      "offsetY": 5
    },
    {
      "type": "change",
      "value": "Password123!",
      "selectors": [
        [
          "input[type=\"password\"]"
        ]
      ]
    },
    {
      "type": "click",
      "selectors": [
        [
          "button[type=\"submit\"]"
        ]
      ],
      "target": "main",
      "offsetX": 5,
      "offsetY": 5
    },
    {
      "type": "waitForElement",
      "selectors": [
        [
          "aria/Blockchain Logs"
        ],
        [
          "text/Blockchain Logs"
        ]
      ],
      "timeout": 8000
    },
    {
      "type": "click",
      "selectors": [
        [
          "aria/Blockchain Logs"
        ],
        [
          "text/Blockchain Logs"
        ]
      ],
      "target": "main",
      "offsetX": 5,
      "offsetY": 5
    },
    {
      "type": "waitForElement",
      "selectors": [
        [
          "text/On-Chain Record Counts"
        ]
      ],
      "timeout": 6000
    },
    {
      "type": "customStep",
      "name": "pause-on-counts",
      "parameters": {
        "ms": 4000
      }
    },
    {
      "type": "click",
      "selectors": [
        [
          "text/Run Verification"
        ]
      ],
      "target": "main",
      "offsetX": 5,
      "offsetY": 5
    },
    {
      "type": "customStep",
      "name": "pause-for-verify-result",
      "parameters": {
        "ms": 6000
      }
    }
  ]
}
