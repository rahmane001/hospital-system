{
  "title": "HMS DApp — Patient Books Appointment (Demo Part 1B)",
  "steps": [
    {
      "type": "setViewport",
      "width": 1920,
      "height": 1080,
      "deviceScaleFactor": 1,
      "isMobile": false,
      "hasTouch": false,
      "isLandscape": true
    },
    {
      "type": "navigate",
      "url": "http://localhost:3000/login"
    },
    {
      "type": "waitForElement",
      "selectors": [["input[type=\"email\"]"]],
      "timeout": 5000
    },
    {
      "type": "click",
      "selectors": [["input[type=\"email\"]"]],
      "target": "main"
    },
    {
      "type": "change",
      "value": "patient@hms.com",
      "selectors": [["input[type=\"email\"]"]]
    },
    {
      "type": "click",
      "selectors": [["input[type=\"password\"]"]],
      "target": "main"
    },
    {
      "type": "change",
      "value": "Password123!",
      "selectors": [["input[type=\"password\"]"]]
    },
    {
      "type": "click",
      "selectors": [["button[type=\"submit\"]"]],
      "target": "main"
    },
    {
      "type": "waitForElement",
      "selectors": [["text/Welcome"]],
      "timeout": 8000
    },
    {
      "type": "customStep",
      "name": "pause-on-patient-home",
      "parameters": { "ms": 3000 }
    },
    {
      "type": "click",
      "selectors": [["aria/Find Doctors"], ["text/Find Doctors"]],
      "target": "main"
    },
    {
      "type": "waitForElement",
      "selectors": [["text/Find a Doctor"]],
      "timeout": 6000
    },
    {
      "type": "customStep",
      "name": "pause-on-doctor-list",
      "parameters": { "ms": 3000 }
    },
    {
      "type": "click",
      "selectors": [["text/View Available Slots"]],
      "target": "main"
    },
    {
      "type": "waitForElement",
      "selectors": [["text/Book Appointment"]],
      "timeout": 6000
    },
    {
      "type": "customStep",
      "name": "pause-on-slots",
      "parameters": { "ms": 3000 }
    },
    {
      "type": "click",
      "selectors": [["text/Book Appointment"]],
      "target": "main"
    },
    {
      "type": "customStep",
      "name": "pause-on-confirm",
      "parameters": { "ms": 4000 }
    },
    {
      "type": "click",
      "selectors": [["aria/My Appointments"], ["text/My Appointments"]],
      "target": "main"
    },
    {
      "type": "customStep",
      "name": "pause-on-appointments",
      "parameters": { "ms": 4000 }
    }
  ]
}
