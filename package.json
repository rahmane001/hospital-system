{
  "name": "hospital-system",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "test": "jest --detectOpenHandles --forceExit",
    "lint": "eslint src/ --ext .js",
    "start": "node server.js",
    "dev": "nodemon server.js"
  },
  "keywords": ["hospital", "blockchain", "ethereum", "solidity", "react", "dapp"],
  "author": "Esha Rahman",
  "license": "MIT",
  "description": "Hospital Management DApp with on-chain audit trail (CN6035 coursework)",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-validator": "^7.3.1",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "mongoose": "^6.13.5",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "web3": "^1.10.0",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/frontend/",
      "/blockchain/"
    ]
  }
}
